---
layout: null
permalink: /search-data.json
---
[
{% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "content": {{ post.content | strip_html | strip_newlines | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | strip_newlines | jsonify }},
    "category": {{ post.category | default: post.categories[0] | default: "" | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%d %b %Y" | jsonify }},
    "author": {{ post.author | default: "Unknown" | jsonify }},
    "image": {{ post.image | default: post.featured_image | default: site.data.theme.meta_og_image | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
